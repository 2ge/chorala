# syntax=docker/dockerfile:1
# Heed API (Hono). Internal packages export TS source, so the API runs via tsx.
FROM node:22-slim AS base
RUN corepack enable
WORKDIR /app

COPY . .
RUN pnpm install --frozen-lockfile

ENV NODE_ENV=production
EXPOSE 8787
# Apply migrations on boot, then serve.
CMD ["sh", "-c", "pnpm db:migrate && pnpm --filter @heed/api start"]
