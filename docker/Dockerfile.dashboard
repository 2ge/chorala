# syntax=docker/dockerfile:1
# Heed dashboard + portal (Next.js 15).
FROM node:22-slim AS base
RUN corepack enable
WORKDIR /app

COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @heed/dashboard build

ENV NODE_ENV=production
EXPOSE 3015
CMD ["pnpm", "--filter", "@heed/dashboard", "start"]
