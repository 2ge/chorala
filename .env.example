# =============================================================================
# Chorala — environment template. Copy to .env and fill required values.
#   cp .env.example .env
# packages/config zod-validates these at boot and fails fast if a REQUIRED var
# (DATABASE_URL, CHORALA_AUTH_SECRET) is missing or malformed.
# =============================================================================

# --- Deployment -------------------------------------------------------------
CHORALA_DEPLOYMENT=selfhost              # selfhost | cloud
CHORALA_PUBLIC_URL=http://localhost:3000 # base URL of the dashboard/portal
CHORALA_API_URL=http://localhost:8787    # base URL of the API
NODE_ENV=development                  # development | production | test

# --- Database (REQUIRED) ----------------------------------------------------
DATABASE_URL=postgres://chorala:chorala@localhost:5432/chorala

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth (Better Auth) -----------------------------------------------------
CHORALA_AUTH_SECRET=                     # REQUIRED: 32+ byte random string
# Optional OAuth providers for admin login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI (optional; features degrade cleanly if absent) ----------------------
CHORALA_AI_PROVIDER=ollama               # ollama | openai | anthropic | none
CHORALA_AI_BASE_URL=http://localhost:11434
CHORALA_AI_API_KEY=                      # required for openai/anthropic providers
CHORALA_AI_CHAT_MODEL=llama3.1:8b
CHORALA_AI_EMBED_MODEL=nomic-embed-text
CHORALA_AI_DEDUP_THRESHOLD=0.86          # cosine similarity (0-1) to suggest a merge

# --- Email (optional; app logs a warning and runs if absent) ----------------
CHORALA_EMAIL_TRANSPORT=smtp             # smtp | resend | none
CHORALA_EMAIL_FROM=feedback@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# --- Billing (cloud deployment only; inert in selfhost) ---------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# --- Widget / public API ----------------------------------------------------
CHORALA_WIDGET_CDN_URL=http://localhost:8787/widget.js
CHORALA_RATE_LIMIT_PUBLIC=60             # requests/min per IP per project on public API

# Bug-report screenshots: absolute path shared by API + dashboard (must be reachable by both)
CHORALA_UPLOAD_DIR=/var/lib/chorala/uploads
CHORALA_ATTACHMENT_MAX_BYTES=5000000
CHORALA_ATTACHMENT_QUOTA_BYTES=1000000000
