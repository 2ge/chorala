# =============================================================================
# Heed — environment template. Copy to .env and fill required values.
#   cp .env.example .env
# packages/config zod-validates these at boot and fails fast if a REQUIRED var
# (DATABASE_URL, HEED_AUTH_SECRET) is missing or malformed.
# =============================================================================

# --- Deployment -------------------------------------------------------------
HEED_DEPLOYMENT=selfhost              # selfhost | cloud
HEED_PUBLIC_URL=http://localhost:3000 # base URL of the dashboard/portal
HEED_API_URL=http://localhost:8787    # base URL of the API
NODE_ENV=development                  # development | production | test

# --- Database (REQUIRED) ----------------------------------------------------
DATABASE_URL=postgres://heed:heed@localhost:5432/heed

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth (Better Auth) -----------------------------------------------------
HEED_AUTH_SECRET=                     # REQUIRED: 32+ byte random string
# Optional OAuth providers for admin login
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI (optional; features degrade cleanly if absent) ----------------------
HEED_AI_PROVIDER=ollama               # ollama | openai | anthropic | none
HEED_AI_BASE_URL=http://localhost:11434
HEED_AI_API_KEY=                      # required for openai/anthropic providers
HEED_AI_CHAT_MODEL=llama3.1:8b
HEED_AI_EMBED_MODEL=nomic-embed-text
HEED_AI_DEDUP_THRESHOLD=0.86          # cosine similarity (0-1) to suggest a merge

# --- Email (optional; app logs a warning and runs if absent) ----------------
HEED_EMAIL_TRANSPORT=smtp             # smtp | resend | none
HEED_EMAIL_FROM=feedback@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# --- Billing (cloud deployment only; inert in selfhost) ---------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# --- Widget / public API ----------------------------------------------------
HEED_WIDGET_CDN_URL=http://localhost:8787/widget.js
HEED_RATE_LIMIT_PUBLIC=60             # requests/min per IP per project on public API
