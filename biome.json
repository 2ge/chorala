{
  "$schema": "https://biomejs.dev/schemas/2.3.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/.next",
      "!**/node_modules",
      "!**/.turbo",
      "!LICENSE",
      "!**/*.gen.ts",
      "!**/widget-demo.html",
      "!**/*.css",
      "!**/next-env.d.ts",
      "!**/openapi.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "asNeeded"
    }
  },
  "overrides": [
    {
      "includes": ["**/test/**", "**/*.test.ts", "**/seed.ts"],
      "linter": { "rules": { "style": { "noNonNullAssertion": "off" } } }
    },
    {
      "includes": ["packages/widget/src/mount.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/dashboard/**"],
      "linter": { "rules": { "a11y": { "noLabelWithoutControl": "off" } } }
    }
  ]
}
