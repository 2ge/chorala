{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "CHORALA_*",
    "DATABASE_URL",
    "REDIS_URL",
    "RESEND_API_KEY",
    "SMTP_*",
    "STRIPE_*",
    "GITHUB_*",
    "GOOGLE_*"
  ],
  "globalDependencies": [".env", "packages/tsconfig/base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "cache": false
    }
  }
}
